# tilde — Personal Cloud Server
# Copy to .env and fill in your values

# =============================================================================
# REQUIRED
# =============================================================================

# Admin password (will be Argon2id hashed on first use)
TILDE_ADMIN_PASSWORD=

# Public hostname for ACME certificate and URL generation
TILDE_HOSTNAME=cloud.example.com

# Email for Let's Encrypt ACME registration
TILDE_ACME_EMAIL=you@example.com

# Backup repository encryption password (generated during `tilde init`, keep safe)
TILDE_BACKUP_PASSWORD=

# =============================================================================
# EMAIL ARCHIVE (optional — enable in config.toml)
# =============================================================================

# IMAP server for email archival
# Purelymail: imap.purelymail.com
TILDE_EMAIL_IMAP_HOST=imap.purelymail.com
TILDE_EMAIL_IMAP_PORT=993
TILDE_EMAIL_USERNAME=you@example.com
TILDE_EMAIL_PASSWORD=

# =============================================================================
# NOTIFICATIONS (optional — configure sinks in config.toml)
# =============================================================================

# ntfy.sh push notifications
# Create a topic at https://ntfy.sh/ (or self-host)
TILDE_NTFY_TOPIC=https://ntfy.sh/your-private-topic
TILDE_NTFY_TOKEN=

# SMTP for email notifications (uses your existing mail provider)
TILDE_SMTP_HOST=smtp.purelymail.com
TILDE_SMTP_PORT=587
TILDE_SMTP_USERNAME=you@example.com
TILDE_SMTP_PASSWORD=

# Matrix notifications
# Get token: Element → Settings → Help & About → Access Token
TILDE_MATRIX_HOMESERVER=https://matrix.org
TILDE_MATRIX_TOKEN=
TILDE_MATRIX_ROOM=!roomid:matrix.org

# Signal notifications (requires signal-cli REST API running)
# See: https://github.com/bbernhard/signal-cli-rest-api
TILDE_SIGNAL_API_URL=http://localhost:8080
TILDE_SIGNAL_RECIPIENT=+1234567890

# =============================================================================
# OFFSITE BACKUP (optional — configure in config.toml)
# =============================================================================

# Backblaze B2 (S3-compatible)
# Get keys at: https://secure.backblaze.com/app_keys.htm
TILDE_BACKUP_B2_KEY_ID=
TILDE_BACKUP_B2_KEY=
TILDE_BACKUP_B2_BUCKET=tilde-backups
